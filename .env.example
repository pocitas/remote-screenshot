# Grabber (Python)
SERVER_WS_URL=ws://localhost:8080/ws/grabber
# Shared secret (private): MUST exactly match Server GRABBER_PSK.
# Generate >=32 random bytes (64 preferred): openssl rand -base64 32
GRABBER_PSK=MUST_MATCH_SERVER_GRABBER_PSK__GENERATE_RANDOM_32B_OR_MORE
GRABBER_ID=pi-01
RECONNECT_DELAY_SECONDS=5
SIMILARITY_THRESHOLD=0.80
REFERENCE_IMAGES_DIR=references
FAILED_IMAGES_DIR=failed_captures

# Server (Go)
ADDR=:8080
# Shared secret (private): MUST exactly match Grabber GRABBER_PSK.
# Generate >=32 random bytes (64 preferred): python3 -c "import secrets; print(secrets.token_urlsafe(32))"
GRABBER_PSK=MUST_MATCH_GRABBER_GRABBER_PSK__GENERATE_RANDOM_32B_OR_MORE
# Shared secret with gate app: MUST match gate-app PUBLIC_GATE_SECRET.
# Generate >=32 random bytes: openssl rand -base64 32
GATE_SECRET=MUST_MATCH_GATE_APP_PUBLIC_GATE_SECRET__GENERATE_RANDOM_32B_OR_MORE
# Server-only signing secret (private): do NOT expose to gate/viewer clients.
# Generate >=64 random bytes preferred: openssl rand -base64 64
JWT_SECRET=SERVER_ONLY_JWT_SIGNING_SECRET__GENERATE_RANDOM_64B_PREFERRED
DB_PATH=./validation.db
FAILED_IMAGES_DIR=./failed-images

# Admin UI authentication
# Store the admin password itself in your password manager, then store only its Argon2id hash here.
# Hash generator: pip install argon2-cffi && python3 -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('paste-password-from-password-manager'))"
ADMIN_PASSWORD_HASH=ARGON2ID_HASH_OF_PASSWORD_MANAGER_ADMIN_PASSWORD
# Server-only session cookie secret (private): independent from JWT_SECRET (do not reuse).
# Generate >=64 random bytes preferred: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
ADMIN_SESSION_SECRET=SERVER_ONLY_ADMIN_SESSION_SECRET__NOT_EQUAL_JWT_SECRET__GENERATE_RANDOM_64B_PREFERRED
