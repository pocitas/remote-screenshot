PUBLIC_SERVER_URL=http://localhost:8080
# Gate API secret/key used to call server POST /api/gate/token.
# MUST exactly match server GATE_SECRET. Treat as sensitive even though variable is PUBLIC_* in this app.
# Generate >=32 random bytes: openssl rand -base64 32
PUBLIC_GATE_SECRET=MUST_MATCH_SERVER_GATE_SECRET__GENERATE_RANDOM_32B_OR_MORE
